# ============================================================================
# Tmux Config Sync
# ============================================================================
tmux-push() {
  local server="${1:-$(dev list 2>/dev/null | grep -oE '[0-9]+\.od' | head -1)}"

  if [[ -z "$server" ]]; then
    echo "Usage: tmux-push [host]"
    echo "No OD found. Specify a host like: tmux-push myserver.sb.facebook.com"
    return 1
  fi

  [[ "$server" =~ ^[0-9]+\.od$ ]] && server="${server}.fbinfra.net"

  if [[ ! -f ~/.tmux.conf ]]; then
    echo "❌ No ~/.tmux.conf found"
    return 1
  fi

  echo "📤 Pushing .tmux.conf to $server..."
  scp ~/.tmux.conf "${server}:~/.tmux.conf" && \
  ssh "$server" "tmux source-file ~/.tmux.conf 2>/dev/null || true; echo '✅ Tmux config synced and reloaded'"
}

tmux-pull() {
  local server="${1:-$(dev list 2>/dev/null | grep -oE '[0-9]+\.od' | head -1)}"

  if [[ -z "$server" ]]; then
    echo "Usage: tmux-pull [host]"
    return 1
  fi

  [[ "$server" =~ ^[0-9]+\.od$ ]] && server="${server}.fbinfra.net"

  echo "📥 Pulling .tmux.conf from $server..."
  scp "${server}:~/.tmux.conf" ~/.tmux.conf && \
  tmux source-file ~/.tmux.conf 2>/dev/null || true
  echo "✅ Tmux config pulled and reloaded"
}

alias tpush='tmux-push'
alias tpull='tmux-pull'

# ============================================================================
# Dotfiles Sync for Claude Merging
# ============================================================================
# Pulls dotfiles from OD to staging directory for Claude to merge
# Location: /tmp/dotfiles-od/

DOTFILES_STAGE="/tmp/dotfiles-od"
DOTFILES_LIST=(.tmux.conf .zshrc .vimrc .gitconfig)

dotpull() {
  local server="${1:-$(dev list 2>/dev/null | grep -oE '[0-9]+\.od' | head -1)}"

  if [[ -z "$server" ]]; then
    echo "❌ No OD server found. Usage: dotpull [host]"
    return 1
  fi

  [[ "$server" =~ ^[0-9]+\.od$ ]] && server="${server}.fbinfra.net"

  # Create staging directory
  mkdir -p "$DOTFILES_STAGE"

  echo "📥 Pulling dotfiles from $server to $DOTFILES_STAGE/"
  echo "─────────────────────────────────────────────────"

  for dotfile in "${DOTFILES_LIST[@]}"; do
    if scp -q "${server}:~/${dotfile}" "${DOTFILES_STAGE}/${dotfile}.od" 2>/dev/null; then
      echo "  ✅ ${dotfile} → ${DOTFILES_STAGE}/${dotfile}.od"
    else
      echo "  ⏭️  ${dotfile} (not found on OD)"
    fi
  done

  echo "─────────────────────────────────────────────────"
  echo ""
  echo "📁 Staged OD dotfiles: $DOTFILES_STAGE/"
  ls -la "$DOTFILES_STAGE/"
  echo ""
  echo "💡 Tell Claude: 'merge dotfiles from $DOTFILES_STAGE with my local configs'"
}

dotpush() {
  local server="${1:-$(dev list 2>/dev/null | grep -oE '[0-9]+\.od' | head -1)}"

  if [[ -z "$server" ]]; then
    echo "❌ No OD server found. Usage: dotpush [host]"
    return 1
  fi

  [[ "$server" =~ ^[0-9]+\.od$ ]] && server="${server}.fbinfra.net"

  echo "📤 Pushing dotfiles to $server"
  echo "─────────────────────────────────────────────────"

  for dotfile in "${DOTFILES_LIST[@]}"; do
    if [[ -f ~/"$dotfile" ]]; then
      if scp -q ~/"$dotfile" "${server}:~/${dotfile}" 2>/dev/null; then
        echo "  ✅ ${dotfile}"
      else
        echo "  ❌ ${dotfile} (failed)"
      fi
    fi
  done

  echo "─────────────────────────────────────────────────"
  echo "✅ Done"
}

