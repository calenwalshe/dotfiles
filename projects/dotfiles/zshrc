  echo ""

  # Check if we have active ODs
  local servers=($(dev list 2>/dev/null | grep -oE '[0-9]+\.od' | sort -u))

  if [[ ${#servers[@]} -eq 0 ]]; then
    echo "No active OD instances. Create one first, then restore."
    echo ""
    read "create?Create new instance now? [y/N]: "
    if [[ "$create" == "y" || "$create" == "Y" ]]; then
      _od_new_instance
      echo ""
      echo "After connecting, run: sudo bkuptool restore --host <old_hostname> --force"
    fi
    return 0
  fi

  echo "Enter the OLD hostname to restore FROM (e.g., 12345.od):"
  read "old_host?Old hostname: "

  if [[ -z "$old_host" ]]; then
    echo "No hostname provided."
    return 1
  fi

  # Normalize hostname
  [[ "$old_host" =~ ^[0-9]+$ ]] && old_host="${old_host}.od"

  echo ""
  echo "Select the OD to restore TO:"
  local i=1
  for s in "${servers[@]}"; do
    echo "  $i) $s"
    ((i++))
  done
  read "choice?> "

  local target_od=""
  if [[ "$choice" -ge 1 && "$choice" -le ${#servers[@]} ]] 2>/dev/null; then
    target_od="${servers[$choice]}"
  else
    echo "Invalid selection"
    return 1
  fi

  local target_fqdn="${target_od}.fbinfra.net"

  echo ""
  echo "╭─────────────────────────────────────────────────────╮"
  echo "│ Ready to restore:                                   │"
  echo "│   FROM: $old_host"
  echo "│   TO:   $target_od"
  echo "╰─────────────────────────────────────────────────────╯"
  echo ""
  read "confirm?Proceed? [y/N]: "

  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Cancelled."
    return 0
  fi

  echo ""
  echo "Restoring home directory..."
  echo "Running: ssh $target_fqdn 'sudo bkuptool restore --host $old_host --force'"
  echo ""

  ssh "$target_fqdn" "sudo bkuptool restore --host $old_host --force"
  local exit_code=$?

  if [[ $exit_code -eq 0 ]]; then
    echo ""
    echo "✓ Home directory restored successfully!"
    echo ""
    read "connect?Connect to $target_od now? [Y/n]: "
    if [[ "$connect" != "n" && "$connect" != "N" ]]; then
      _od_connect_existing "$target_od"
    fi
  else
    echo ""
    echo "✗ Restore failed (exit code: $exit_code)"
    echo "  Try running manually: sudo bkuptool find --host $old_host"
  fi

  return $exit_code
}

