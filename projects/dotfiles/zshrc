# Release instance
_od_release() {
  local servers=("$@")

  echo ""
  echo "Release which instance?"
  local i=1
  for s in "${servers[@]}"; do
    echo "  $i) $s"
    ((i++))
  done
  echo "  a) All instances"
  read "choice?> "

  if [[ "$choice" == "a" || "$choice" == "A" ]]; then
    echo "Releasing all instances..."
    dev release --all
  elif [[ "$choice" -ge 1 && "$choice" -le ${#servers[@]} ]] 2>/dev/null; then
