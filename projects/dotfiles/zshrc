# ============================================================================
# Lena Machine SSH Control Socket (persistent connection)
# ============================================================================
LENA_HOST="calen@lenawin"
LENA_SOCKET="/tmp/ssh-lena-control"

lena-connect() {
  if [[ -S "$LENA_SOCKET" ]]; then
    echo "Lena tunnel already active."
    ssh -S "$LENA_SOCKET" -O check "$LENA_HOST" 2>/dev/null && return 0
    echo "Stale socket found, cleaning up..."
    rm -f "$LENA_SOCKET"
  fi

  echo "Opening persistent SSH connection to Lena..."
  ssh -fNM -S "$LENA_SOCKET" -o ControlPersist=yes "$LENA_HOST"

  if [[ $? -eq 0 ]]; then
    echo "✓ Lena tunnel established. Use 'lena <command>' to run commands."
  else
    echo "✗ Failed to connect to Lena."
    return 1
  fi
}

lena() {
  if [[ ! -S "$LENA_SOCKET" ]]; then
    echo "No active tunnel. Run 'lena-connect' first."
    return 1
  fi

  if [[ $# -eq 0 ]]; then
    ssh -S "$LENA_SOCKET" "$LENA_HOST"
  else
    ssh -S "$LENA_SOCKET" "$LENA_HOST" "$@"
  fi
}

lena-disconnect() {
  if [[ -S "$LENA_SOCKET" ]]; then
    echo "Closing Lena tunnel..."
    ssh -S "$LENA_SOCKET" -O exit "$LENA_HOST" 2>/dev/null
    rm -f "$LENA_SOCKET"
    echo "✓ Lena tunnel closed."
  else
    echo "No active tunnel."
  fi
}

lena-status() {
  if [[ -S "$LENA_SOCKET" ]]; then
    ssh -S "$LENA_SOCKET" -O check "$LENA_HOST" 2>&1
  else
    echo "No active tunnel."
  fi
}

