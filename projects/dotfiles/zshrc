  rsync -avhP \
    --exclude='.claude-templates-manifest.json' \
    $exclude_args \
    --include='agents/***' \
    --include='commands/***' \
    --include='plugins/***' \
    --include='skills/***' \
    --exclude='*' \
    ~/.claude/ "${server}.fbinfra.net":~/.claude/

  echo "✓ Claude config synced!"
}

