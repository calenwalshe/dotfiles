# ============================================================================
# OD File Transfer (SCP)
# ============================================================================
odscp() {
  local servers=($(dev list 2>/dev/null | grep -oE '[0-9]+\.od' | sort -u))

  if [[ ${#servers[@]} -eq 0 ]]; then
    echo "No .od servers found. Run 'dev connect' first."
    return 1
  fi

  local selected
  if [[ ${#servers[@]} -eq 1 ]]; then
    selected="${servers[1]}"
    echo "Using server: $selected"
  else
    echo "Select a server:"
    local i=1
    for s in "${servers[@]}"; do
      echo "  $i) $s"
      ((i++))
    done
    read "choice?> "
    if [[ "$choice" -ge 1 && "$choice" -le ${#servers[@]} ]] 2>/dev/null; then
      selected="${servers[$choice]}"
    else
      echo "Invalid selection"
      return 1
    fi
  fi

  local server_host="${selected}.fbinfra.net"

  local args=()
  for arg in "$@"; do
    if [[ "$arg" == ~* ]]; then
      args+=("${server_host}:${arg}")
    elif [[ "$arg" == :* ]]; then
      args+=("${server_host}${arg}")
    else
      args+=("$arg")
    fi
  done

  echo "Running: scp ${args[*]}"
  scp "${args[@]}"
}

