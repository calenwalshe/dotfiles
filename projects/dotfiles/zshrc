# Main OD manager with interactive TUI
od() {
  local servers=()
  local server_info=()

  # Parse dev list output
  local od_regex='([0-9]+\.od)[[:space:]]*\(([^)]+)\)'
  while IFS= read -r line; do
    if [[ "$line" =~ $od_regex ]]; then
      servers+=("${match[1]}")
      server_info+=("${match[1]} (${match[2]})")
    fi
  done < <(dev list 2>/dev/null | grep -E '[0-9]+\.od')

  # Display header
  echo ""
  echo "╭─ OnDemand Manager ─────────────────────────────────╮"

  # Show active instances
  if [[ ${#servers[@]} -gt 0 ]]; then
    echo "│ Active Instances:                                  │"
    local i=1
    for info in "${server_info[@]}"; do
      printf "│   %d) %-46s │\n" "$i" "$info"
      ((i++))
    done
  else
    echo "│ Active Instances: (none)                           │"
  fi

  echo "├────────────────────────────────────────────────────┤"
  echo "│ Actions:                                           │"
  if [[ ${#servers[@]} -gt 0 ]]; then
    echo "│   [c] Connect to existing instance                 │"
  fi
  echo "│   [n] New instance                                  │"
  echo "│   [b] Restore from backup                           │"
  if [[ ${#servers[@]} -gt 0 ]]; then
    echo "│   [r] Release instance                             │"
  fi
  echo "│   [q] Quit                                          │"
  echo "╰────────────────────────────────────────────────────╯"
  echo ""

  read "action?> "

  case "$action" in
    c|C)
      if [[ ${#servers[@]} -eq 0 ]]; then
        echo "No instances to connect to."
        return 1
      fi
      _od_connect_existing "${servers[@]}"
      ;;
    n|N)
      _od_new_instance
      ;;
    b|B)
      _od_restore_backup
      ;;
    r|R)
      if [[ ${#servers[@]} -eq 0 ]]; then
        echo "No instances to release."
        return 1
      fi
      _od_release "${servers[@]}"
      ;;
    q|Q|"")
      return 0
      ;;
    *)
      echo "Invalid selection"
      return 1
      ;;
  esac
}

# Connect to existing instance
_od_connect_existing() {
  local servers=("$@")

  if [[ ${#servers[@]} -eq 1 ]]; then
    local selected="${servers[1]}"
  else
    echo ""
    echo "Select instance:"
    local i=1
    for s in "${servers[@]}"; do
      echo "  $i) $s"
      ((i++))
    done
    read "choice?> "

    if [[ "$choice" -ge 1 && "$choice" -le ${#servers[@]} ]] 2>/dev/null; then
      selected="${servers[$choice]}"
    else
      echo "Invalid selection"
      return 1
    fi
  fi

  echo ""
  echo "Connection type: [e]t (recommended)  [m]osh  [s]sh"
  read "conn?> "

  local conn_flag="--et"
  case "$conn" in
    m|M) conn_flag="--mosh" ;;
    s|S) conn_flag="--ssh" ;;
  esac

  local server_fqdn="${selected}.fbinfra.net"
  echo "Connecting to ${server_fqdn}..."

  # Blue-purple tint for OD sessions
  printf '\033]11;#1e1e28\007'

  dev connect $conn_flag --hostname "$selected"
  local exit_code=$?

  # Restore black background
  printf '\033]11;#000000\007'
  return $exit_code
}

