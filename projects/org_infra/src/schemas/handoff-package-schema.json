{
  "$defs": {
    "AlignmentItem": {
      "properties": {
        "internal_finding": {
          "title": "Internal Finding",
          "type": "string"
        },
        "external_input": {
          "title": "External Input",
          "type": "string"
        },
        "assessment": {
          "default": "",
          "title": "Assessment",
          "type": "string"
        }
      },
      "required": [
        "internal_finding",
        "external_input"
      ],
      "title": "AlignmentItem",
      "type": "object"
    },
    "Assumption": {
      "properties": {
        "statement": {
          "title": "Statement",
          "type": "string"
        },
        "status": {
          "default": "open",
          "title": "Status",
          "type": "string"
        },
        "owner": {
          "default": "engineering",
          "title": "Owner",
          "type": "string"
        },
        "resolution_needed_by": {
          "default": "",
          "title": "Resolution Needed By",
          "type": "string"
        }
      },
      "required": [
        "statement"
      ],
      "title": "Assumption",
      "type": "object"
    },
    "ConflictItem": {
      "properties": {
        "internal_finding": {
          "title": "Internal Finding",
          "type": "string"
        },
        "external_input": {
          "title": "External Input",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "medium"
        },
        "recommended_resolution": {
          "default": "",
          "title": "Recommended Resolution",
          "type": "string"
        }
      },
      "required": [
        "internal_finding",
        "external_input"
      ],
      "title": "ConflictItem",
      "type": "object"
    },
    "EvalCriteria": {
      "properties": {
        "success_criteria": {
          "items": {
            "$ref": "#/$defs/SuccessCriterion"
          },
          "title": "Success Criteria",
          "type": "array"
        },
        "guardrails": {
          "items": {
            "type": "string"
          },
          "title": "Guardrails",
          "type": "array"
        }
      },
      "title": "EvalCriteria",
      "type": "object"
    },
    "EvidenceItem": {
      "properties": {
        "source": {
          "title": "Source",
          "type": "string"
        },
        "finding": {
          "title": "Finding",
          "type": "string"
        },
        "confidence": {
          "default": "medium",
          "title": "Confidence",
          "type": "string"
        }
      },
      "required": [
        "source",
        "finding"
      ],
      "title": "EvidenceItem",
      "type": "object"
    },
    "FeedbackSynthesis": {
      "properties": {
        "stakeholder_inputs": {
          "items": {
            "$ref": "#/$defs/StakeholderInput"
          },
          "title": "Stakeholder Inputs",
          "type": "array"
        },
        "alignments": {
          "items": {
            "$ref": "#/$defs/AlignmentItem"
          },
          "title": "Alignments",
          "type": "array"
        },
        "conflicts": {
          "items": {
            "$ref": "#/$defs/ConflictItem"
          },
          "title": "Conflicts",
          "type": "array"
        }
      },
      "title": "FeedbackSynthesis",
      "type": "object"
    },
    "OpenAssumptions": {
      "properties": {
        "assumptions": {
          "items": {
            "$ref": "#/$defs/Assumption"
          },
          "title": "Assumptions",
          "type": "array"
        }
      },
      "title": "OpenAssumptions",
      "type": "object"
    },
    "PackageMetadata": {
      "properties": {
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "run_id": {
          "default": "",
          "title": "Run Id",
          "type": "string"
        },
        "source_agents": {
          "items": {
            "type": "string"
          },
          "title": "Source Agents",
          "type": "array"
        }
      },
      "title": "PackageMetadata",
      "type": "object"
    },
    "Persona": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "needs": {
          "items": {
            "type": "string"
          },
          "title": "Needs",
          "type": "array"
        },
        "pain_points": {
          "items": {
            "type": "string"
          },
          "title": "Pain Points",
          "type": "array"
        },
        "data_sources": {
          "items": {
            "type": "string"
          },
          "title": "Data Sources",
          "type": "array"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "title": "Persona",
      "type": "object"
    },
    "Priority": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "title": "Priority",
      "type": "string"
    },
    "ProblemStatement": {
      "properties": {
        "statement": {
          "description": "Validated problem statement",
          "title": "Statement",
          "type": "string"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceItem"
          },
          "title": "Evidence",
          "type": "array"
        },
        "target_users": {
          "items": {
            "type": "string"
          },
          "title": "Target Users",
          "type": "array"
        },
        "validated": {
          "default": false,
          "title": "Validated",
          "type": "boolean"
        }
      },
      "required": [
        "statement"
      ],
      "title": "ProblemStatement",
      "type": "object"
    },
    "ProductPitch": {
      "properties": {
        "title": {
          "title": "Title",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "value_proposition": {
          "title": "Value Proposition",
          "type": "string"
        },
        "target_audience": {
          "title": "Target Audience",
          "type": "string"
        },
        "differentiation": {
          "default": "",
          "title": "Differentiation",
          "type": "string"
        }
      },
      "required": [
        "title",
        "summary",
        "value_proposition",
        "target_audience"
      ],
      "title": "ProductPitch",
      "type": "object"
    },
    "Requirement": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "priority": {
          "$ref": "#/$defs/Priority"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string"
        },
        "acceptance_criteria": {
          "items": {
            "type": "string"
          },
          "title": "Acceptance Criteria",
          "type": "array"
        }
      },
      "required": [
        "id",
        "description",
        "priority"
      ],
      "title": "Requirement",
      "type": "object"
    },
    "Requirements": {
      "properties": {
        "build": {
          "description": "What to build",
          "items": {
            "$ref": "#/$defs/Requirement"
          },
          "title": "Build",
          "type": "array"
        },
        "not_build": {
          "description": "What not to build, with reasons",
          "items": {
            "type": "string"
          },
          "title": "Not Build",
          "type": "array"
        },
        "prioritization_rationale": {
          "default": "",
          "title": "Prioritization Rationale",
          "type": "string"
        }
      },
      "title": "Requirements",
      "type": "object"
    },
    "Risk": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "likelihood": {
          "default": "medium",
          "title": "Likelihood",
          "type": "string"
        },
        "mitigation": {
          "default": "",
          "title": "Mitigation",
          "type": "string"
        },
        "owner": {
          "default": "",
          "title": "Owner",
          "type": "string"
        }
      },
      "required": [
        "id",
        "description",
        "severity"
      ],
      "title": "Risk",
      "type": "object"
    },
    "RiskLog": {
      "properties": {
        "risks": {
          "items": {
            "$ref": "#/$defs/Risk"
          },
          "title": "Risks",
          "type": "array"
        }
      },
      "title": "RiskLog",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "title": "Severity",
      "type": "string"
    },
    "StakeholderInput": {
      "properties": {
        "stakeholder": {
          "title": "Stakeholder",
          "type": "string"
        },
        "input_text": {
          "title": "Input Text",
          "type": "string"
        },
        "sentiment": {
          "default": "",
          "title": "Sentiment",
          "type": "string"
        }
      },
      "required": [
        "stakeholder",
        "input_text"
      ],
      "title": "StakeholderInput",
      "type": "object"
    },
    "SuccessCriterion": {
      "properties": {
        "metric": {
          "title": "Metric",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "measurement_method": {
          "default": "",
          "title": "Measurement Method",
          "type": "string"
        }
      },
      "required": [
        "metric",
        "target"
      ],
      "title": "SuccessCriterion",
      "type": "object"
    },
    "TestCase": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "category": {
          "default": "",
          "title": "Category",
          "type": "string"
        },
        "expected_behavior": {
          "default": "",
          "title": "Expected Behavior",
          "type": "string"
        }
      },
      "required": [
        "name",
        "description"
      ],
      "title": "TestCase",
      "type": "object"
    },
    "TestHarnessConcept": {
      "properties": {
        "intent": {
          "description": "What the test harness is designed to validate",
          "title": "Intent",
          "type": "string"
        },
        "structure": {
          "items": {
            "$ref": "#/$defs/TestCase"
          },
          "title": "Structure",
          "type": "array"
        },
        "coverage_areas": {
          "items": {
            "type": "string"
          },
          "title": "Coverage Areas",
          "type": "array"
        }
      },
      "required": [
        "intent"
      ],
      "title": "TestHarnessConcept",
      "type": "object"
    },
    "UserResearch": {
      "properties": {
        "personas": {
          "items": {
            "$ref": "#/$defs/Persona"
          },
          "title": "Personas",
          "type": "array"
        },
        "problem_validation": {
          "items": {
            "$ref": "#/$defs/EvidenceItem"
          },
          "title": "Problem Validation",
          "type": "array"
        },
        "user_signals": {
          "items": {
            "type": "string"
          },
          "title": "User Signals",
          "type": "array"
        },
        "methodology": {
          "default": "",
          "title": "Methodology",
          "type": "string"
        }
      },
      "title": "UserResearch",
      "type": "object"
    }
  },
  "properties": {
    "metadata": {
      "$ref": "#/$defs/PackageMetadata"
    },
    "problem_statement": {
      "$ref": "#/$defs/ProblemStatement"
    },
    "user_research": {
      "$ref": "#/$defs/UserResearch"
    },
    "product_pitch": {
      "$ref": "#/$defs/ProductPitch"
    },
    "requirements": {
      "$ref": "#/$defs/Requirements"
    },
    "eval_criteria": {
      "$ref": "#/$defs/EvalCriteria"
    },
    "test_harness_concept": {
      "$ref": "#/$defs/TestHarnessConcept"
    },
    "feedback_synthesis": {
      "$ref": "#/$defs/FeedbackSynthesis"
    },
    "risk_log": {
      "$ref": "#/$defs/RiskLog"
    },
    "open_assumptions": {
      "$ref": "#/$defs/OpenAssumptions"
    }
  },
  "required": [
    "problem_statement",
    "user_research",
    "product_pitch",
    "requirements",
    "eval_criteria",
    "test_harness_concept",
    "feedback_synthesis",
    "risk_log",
    "open_assumptions"
  ],
  "title": "HandoffPackage",
  "type": "object"
}