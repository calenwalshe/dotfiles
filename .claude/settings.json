{
  "permissions": {
    "allow": [
      "Edit(/home/agent/**)",
      "Write(/home/agent/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/sessionstart-snapshot.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/ctrl-session-start.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-session-start.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/sessionstart-memory-nudge.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-memory-sessionstart.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/sessionstart-postclear-recall.sh",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/agent/.claude/hooks/otel-session-start.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-precompact.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/precompact-memory-snapshot.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/precompact-session-snapshot.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/sessionend-session-summary.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/sessionend-db-update.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-session-end.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/sessionend-turns.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/agent/.claude/hooks/otel-session-end.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-postcompact.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=~/.claude/context-store python3 ~/.claude/hooks/context-capture.py",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-memory-sessionend.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=~/.claude/context-store python3 ~/.claude/hooks/context-capture.py",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-phase-guard.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-critique-guard.sh",
            "timeout": 60
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-research-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/postuse-git-episode.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-validator-trigger.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/gdrive-html-upload.sh",
            "timeout": 30,
            "statusMessage": "Uploading to Google Drive..."
          },
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/caddy-deploy.sh",
            "timeout": 60,
            "statusMessage": "Validating Caddy config..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/postuse-event-logger.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-memory-track-session.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/token-ledger.js",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-context-capacity.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=~/.claude/context-store python3 ~/.claude/hooks/context-capture.py",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/agent/.claude/hooks/otel-post-tool-use.sh",
            "async": true
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-task-created.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-task-completed.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-teammate-idle.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "ui-designer@daymade-skills": true,
    "design-studio@design-studio": true,
    "token-dashboard@design-studio": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "daymade-skills": {
      "source": {
        "source": "github",
        "repo": "daymade/claude-code-skills"
      }
    },
    "design-studio": {
      "source": {
        "source": "directory",
        "path": "/home/agent/projects/design-studio-marketplace"
      }
    }
  },
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "alwaysThinkingEnabled": false
}