{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/agent/.claude/hooks/gsd-check-update.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "# DISABLED \u2014 replaced by reup-session-start.sh: node \"/home/agent/.claude/hooks/session-resume.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-session-start.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/reup-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-phase-guard.sh",
            "timeout": 10
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/agent/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/agent/.claude/hooks/context-checkpoint.js\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-sync.sh",
            "statusMessage": "Syncing Cortex skill to GitHub...",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-validator-trigger.sh",
            "async": true
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-distribute.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-precompact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-postcompact.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-session-end.sh",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/reup-stop.sh",
            "async": true
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-task-created.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-task-completed.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/agent/.claude/hooks/cortex-teammate-idle.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/home/agent/.claude/hooks/gsd-statusline.js\""
  },
  "enabledPlugins": {
    "cli-anything@cli-anything": true
  },
  "extraKnownMarketplaces": {
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "sonnet"
}